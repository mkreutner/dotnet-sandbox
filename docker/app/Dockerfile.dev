FROM debian:trixie-slim

ARG UID=1000
ARG GID=1000
ARG USERNAME=developer

# 1. Installation des dépendances système adaptées à Trixie
RUN apt update && apt install -y --no-install-recommends \
  bash \
  curl \
  git \
  sudo \
  tzdata \
  build-essential \
  ca-certificates \
  # Dépendances natives requises par le runtime .NET sur Debian Trixie
  libc6 \
  libgcc-s1 \
  libgssapi-krb5-2 \
  libicu76 \
  libssl3t64 \
  libstdc++6 \
  zlib1g \
  && rm -rf /var/lib/apt/lists/*

# 2. Création et configuration de l'utilisateur
RUN groupadd -g "${GID}" "${USERNAME}" \
  && useradd -u "${UID}" -g "${GID}" -m -s /bin/bash "${USERNAME}" \
  && echo "${USERNAME} ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers.d/${USERNAME}

USER ${USERNAME}
WORKDIR /home/${USERNAME}

# 3. Variables d'environnement pour .NET
ENV DOTNET_ROOT=/home/${USERNAME}/.dotnet
ENV PATH=$PATH:$DOTNET_ROOT:$DOTNET_ROOT/tools

# 4. Installation du SDK .NET 10 via le script officiel
RUN curl -sSL https://dot.net/v1/dotnet-install.sh -o dotnet-install.sh \
  && chmod +x dotnet-install.sh \
  && ./dotnet-install.sh --channel 10.0 \
  && rm dotnet-install.sh

# 5. Mise à jour des workloads
RUN dotnet workload update
